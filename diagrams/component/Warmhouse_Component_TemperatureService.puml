@startuml
title Warm house Temperature Service Component Diagram

top to bottom direction

!includeurl https://raw.githubusercontent.com/RicardoNiepel/C4-PlantUML/master/C4_Component.puml

Container_Boundary(WarmHouseSystem, "Warm house temperature System") {
  Container(WebApp, "Temperature Service", "Go", "Handles temperature sensor request")
  Container(Database, "Database", "PostgreSQL")
}

Container(WebApp, "Web Application", "Go") {
  Component(TemperatureController, "TemperatureController", "Temperature handler")
  Component(ServiceLayer, "Service Layer", "Business logic")
}

Rel(TemperatureController,ServiceLayer,"Calls business logic")
Rel(ServiceLayer,Database, "Reads/Writes temperature sensor data")
@enduml